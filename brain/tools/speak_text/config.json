{
    "type": "function",
    "name": "speak_text",
    "description": "将文本转为语音播放（仅在PC语音模式开启时有效）。当前默认使用本地 Qwen3-TTS-12Hz-0.6B-Base，以 LingYiVoice.wav 作为声源，支持文本、language 和播放语速。",
    "parameters": {
        "type": "object",
        "properties": {
            "text": {
                "type": "string",
                "description": "要播报的文本内容。"
            },
            "language": {
                "type": "string",
                "description": "语言，如 Auto、Chinese、English、Japanese。"
            },
            "speed": {
                "type": "number",
                "description": "播放语速，范围0.5~2.0，1.0为默认。"
            }
        },
        "required": ["text"]
    }
}