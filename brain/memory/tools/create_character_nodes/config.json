                },
                "context": {
                    "type": "string",
                    "description": "如果该角色为现实存在的角色，则为reality现实。如果是某个网络账号，则为其对应的平台。如果是虚构角色，则为其所属的作品名称。"
                },
                "note": {
                    "type": "string",
                    "description": "备注信息。"
                }
            },
            "required": ["name"]
        }
    }
