{
    "system":{
        "version": "0.5.3", // 版本号
        "ai_name": "铃依", // AI名称
        "user_name": "星空", // 用户名
        "stream_response": true, // 是否启用流式响应
        "debug": false, // 是否启用调试模式
        "log_level": "INFO" // 日志级别
    },
    "api":{
        "api_key": "sk-your-sdk", // 你的sdk，必填！
        "base_url": "api-url", // API基础URL
        "model": "your-model-name", // 使用的模型名称
        "temperature": 0.7, // 温度参数
        "max_tokens": 2048, // 最大token数
        "max_history_rounds": 10, // 最大历史轮数
        "max_history_days": 3, // 加载历史上下文的天数
        "applied_proxy": false // 是否应用代理
    },
    "memory_api" :{ // 记忆系统配置
        "memory_record_api_key": "sk-your-sdk",
        "memory_record_base_url": "https://api.openai.com/v1",
        "memory_record_model": "gpt-5-nano-2025-08-07", // 图谱构建模型
        "embedding_api_key": "Ollama",
        "embedding_base_url": "http://localhost:11434/v1",
        "embedding_model": "nomic-embed-text", // 向量分析模型
        "memory_decay_factor": 0.8 // 记忆衰减因子，范围0-1，值越小衰减越快,1不衰减
    },
    "vision_api": { // 图像分析API配置
        "enabled": true,
        "vision_api_key": "sk-your-sdk",
        "vision_base_url": "https://api.openai.com/v1",
        "vision_model": "gpt-image-1.5-2025-12-16",
    },
    "api_server": {
        "enabled": true,
        "host": "127.0.0.1",
        "port": 8000,
        "auto_start": true
    },
    "agentserver": {
        "enabled": true,
        "host": "127.0.0.1",
        "port": 8001,
        "auto_start": true
    },
    "mcpserver": {
        "enabled": true,
        "host": "127.0.0.1",
        "port": 8003,
        "auto_start": true
    },
    "grag": {
        "enabled": true,
        "auto_extract": true,
        "context_length": 5,
        "similarity_threshold": 0.6,
        "neo4j_uri": "neo4j://127.0.0.1:7687",
        "neo4j_user": "neo4j",
        "neo4j_password": "your_password_here", // 你给neo4j设置的密码
        "neo4j_database": "neo4j",
        "extraction_timeout": 12,
        "extraction_retries": 2,
        "base_timeout": 15
    },
    "ui":{
        "username": "星空",
        "text_size": "10",
        "image_name": "LingYi_img.png"
    },
    "crawl4ai": {
        "headless": true,
        "timeout": 30000,
        "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36",
        "viewport_width": 1280,
        "viewport_height": 720
    }
}